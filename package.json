{
	"name": "realm",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=24.9.0"
	},
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write --list-different .",
		"fmt": "oxfmt --list-different",
		"lint": "oxlint --type-aware --fix --fix-suggestions && eslint .",
		"lint:ci": "prettier --check . && oxfmt --check && oxlint --type-aware && eslint ."
	},
	"dependencies": {
		"@inlang/paraglide-js": "^2.5.0",
		"luxon": "^3.7.2",
		"tiny-invariant": "^1.3.3"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.0",
		"@eslint/js": "^9.39.1",
		"@prettier/plugin-oxc": "^0.0.5",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.48.5",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.2.9",
		"@types/luxon": "^3.7.1",
		"@types/node": "^24.10.1",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-oxlint": "^1.29.0",
		"eslint-plugin-svelte": "^3.13.0",
		"flowbite": "^4.0.1",
		"flowbite-svelte": "^1.28.1",
		"flowbite-svelte-blocks": "^2.1.0",
		"flowbite-svelte-icons": "^3.0.0",
		"globals": "^16.5.0",
		"jsdom": "^27.2.0",
		"oxfmt": "^0.14.0",
		"oxlint": "^1.29.0",
		"oxlint-tsgolint": "^0.7.3",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"svelte": "^5.43.12",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.47.0",
		"vite": "^7.2.4",
		"vitest": "^4.0.12"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild"
		]
	}
}
