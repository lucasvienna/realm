{
	"name": "realm",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"debug": "NODE_OPTIONS=\"--inspect\" vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write --list-different .",
		"fmt": "oxfmt",
		"lint": "oxlint --type-aware --fix --fix-suggestions && eslint --fix .",
		"lint:ci": "prettier --check . && oxfmt --check && oxlint --type-aware && eslint ."
	},
	"dependencies": {
		"@inlang/paraglide-js": "2.7.0",
		"ky": "1.14.1",
		"luxon": "3.7.2",
		"mode-watcher": "1.1.0",
		"tiny-invariant": "1.3.3"
	},
	"devDependencies": {
		"@eslint/compat": "2.0.0",
		"@eslint/js": "9.39.2",
		"@internationalized/date": "3.10.1",
		"@lucide/svelte": "0.562.0",
		"@prettier/plugin-oxc": "0.1.3",
		"@sveltejs/adapter-auto": "7.0.0",
		"@sveltejs/kit": "2.49.2",
		"@sveltejs/vite-plugin-svelte": "6.2.1",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/typography": "0.5.19",
		"@tailwindcss/vite": "4.1.18",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/svelte": "5.2.9",
		"@types/luxon": "3.7.1",
		"@types/node": "24.10.2",
		"bits-ui": "2.14.4",
		"clsx": "2.1.1",
		"eslint": "9.39.2",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-oxlint": "1.33.0",
		"eslint-plugin-svelte": "3.13.1",
		"globals": "16.5.0",
		"jsdom": "27.3.0",
		"oxfmt": "0.18.0",
		"oxlint": "1.33.0",
		"oxlint-tsgolint": "0.9.1",
		"prettier": "3.7.4",
		"prettier-plugin-svelte": "3.4.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"svelte": "5.46.0",
		"svelte-check": "4.3.4",
		"tailwind-merge": "3.4.0",
		"tailwind-variants": "3.2.2",
		"tailwindcss": "4.1.18",
		"tw-animate-css": "1.4.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.50.0",
		"vite": "7.3.0",
		"vite-plugin-devtools-json": "1.0.0",
		"vitest": "4.0.16"
	},
	"engines": {
		"node": ">=24.9.0"
	}
}
