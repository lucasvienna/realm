{
	"name": "realm",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"debug": "NODE_OPTIONS=\"--inspect\" vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest",
		"prepare": "pnpm paraglide || echo '' && svelte-kit sync || echo ''",
		"paraglide": "paraglide-js compile --silent --project ./project.inlang --outdir ./src/lib/paraglide",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"fmt": "pnpm run \"/^fmt:.*/\"",
		"fmt:all": "oxfmt",
		"fmt:svelte": "prettier --write --list-different **/*.svelte",
		"lint": "oxlint --type-aware --fix --fix-suggestions && eslint --fix .",
		"lint:ci": "prettier --check **/*.svelte && oxfmt --check && oxlint --type-aware && eslint ."
	},
	"dependencies": {
		"@inlang/paraglide-js": "2.15.3",
		"bits-ui": "2.17.3",
		"ky": "2.0.1",
		"luxon": "3.7.2",
		"mode-watcher": "1.1.0",
		"tiny-invariant": "1.3.3"
	},
	"devDependencies": {
		"@eslint/compat": "2.0.5",
		"@eslint/js": "10.0.1",
		"@inlang/cli": "3.1.9",
		"@internationalized/date": "3.12.0",
		"@lucide/svelte": "1.8.0",
		"@prettier/plugin-oxc": "0.1.3",
		"@sveltejs/adapter-node": "5.5.4",
		"@sveltejs/kit": "2.57.1",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/typography": "0.5.19",
		"@tailwindcss/vite": "4.2.2",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/svelte": "5.3.1",
		"@types/luxon": "3.7.1",
		"@types/node": "^24.12.2",
		"@vitest/coverage-v8": "4.1.4",
		"clsx": "2.1.1",
		"eslint": "10.2.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-oxlint": "1.60.0",
		"eslint-plugin-svelte": "3.17.0",
		"globals": "17.5.0",
		"jsdom": "29.0.2",
		"oxfmt": "0.45.0",
		"oxlint": "1.60.0",
		"oxlint-tsgolint": "0.21.0",
		"prettier": "3.8.2",
		"prettier-plugin-svelte": "3.5.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"svelte": "5.55.4",
		"svelte-check": "4.4.6",
		"tailwind-merge": "3.5.0",
		"tailwind-variants": "3.2.2",
		"tailwindcss": "4.2.2",
		"tw-animate-css": "1.4.0",
		"typescript": "6.0.2",
		"typescript-eslint": "8.58.2",
		"vite": "8.0.8",
		"vite-plugin-devtools-json": "1.0.0",
		"vitest": "4.1.4"
	},
	"engines": {
		"node": ">=24.9.0"
	}
}
